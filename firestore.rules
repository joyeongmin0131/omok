rules_version = '2';

// 이 앱은 별도 서버 없이 클라이언트가 Firestore에 직접 읽고 쓴다.
// 그래서 "누가 뭘 쓸 수 있는지"를 여기서 최대한 꼼꼼히 막아준다.
//
// 한 가지 한계: 대국이 끝나서 승/패를 기록할 때, 그 수를 둔 클라이언트가
// "내 wins/losses" 뿐 아니라 "상대방의 wins/losses"도 같이 갱신해야 한다
// (트랜잭션 하나로 두 사람 문서를 동시에 바꾸는 구조라서 그렇다).
// 그래서 아래 규칙은 "누구든 로그인한 사용자면 다른 사람의 wins/losses 필드를
// 정확히 +1 만큼만 늘리는 것"을 허용한다 — 진짜 서버가 있었다면 막을 수 있었을
// 부정행위(예: 게임 없이 승수 조작)까지는 막지 못하는 트레이드오프다.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if isSignedIn();

      // 회원가입 시 최초 생성 — 본인 계정만, 승패는 반드시 0부터 시작
      allow create: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.wins == 0
        && request.resource.data.losses == 0;

      // 본인 프로필 수정 (닉네임/캐릭터/사진/접속시간) — wins/losses는 여기선 못 바꾼다.
      // 프로필 사진은 Storage 없이 Firestore에 직접 저장하므로(client/src/lib/image.ts),
      // 문서가 너무 커지지 않도록 사진 데이터 길이도 같이 제한한다.
      allow update: if isSignedIn() && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['wins', 'losses'])
        && (!('photoUrl' in request.resource.data) || request.resource.data.photoUrl == null
            || request.resource.data.photoUrl.size() < 300000);

      // 대국 결과 반영 — wins 또는 losses 필드만, 그것도 정확히 +1만큼만 늘리는 것을 허용
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['wins', 'losses'])
        && request.resource.data.wins <= resource.data.wins + 1
        && request.resource.data.wins >= resource.data.wins
        && request.resource.data.losses <= resource.data.losses + 1
        && request.resource.data.losses >= resource.data.losses;
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn();

      // 방 생성 — 자기 자신을 host로 등록하는 새 방만
      allow create: if isSignedIn()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.status == 'waiting'
        && request.resource.data.guestId == null;

      // 방 수정 — 이미 참가 중인 사람(host/guest) 이거나, 비어있는 방에 새로 들어가는 경우만
      allow update: if isSignedIn() && (
        resource.data.hostId == request.auth.uid ||
        resource.data.guestId == request.auth.uid ||
        (resource.data.guestId == null && request.resource.data.guestId == request.auth.uid)
      );

      // 방 삭제 — 아직 아무도 안 들어온 대기방을, 만든 사람이 취소할 때만
      allow delete: if isSignedIn()
        && resource.data.hostId == request.auth.uid
        && resource.data.status == 'waiting';
    }

    match /invites/{inviteId} {
      // 보낸 사람이거나 받은 사람만 읽을 수 있다
      allow read: if isSignedIn()
        && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);

      // 초대 생성 — 자기 자신을 fromId로 등록하는 새 초대만
      allow create: if isSignedIn()
        && request.resource.data.fromId == request.auth.uid
        && request.resource.data.status == 'pending';

      // 상태 변경 — 받은 사람은 수락/거절만, 보낸 사람은 취소만 할 수 있다
      allow update: if isSignedIn() && (
        (resource.data.toId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && request.resource.data.status in ['accepted', 'declined']) ||
        (resource.data.fromId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && request.resource.data.status == 'cancelled')
      );
    }
  }
}
